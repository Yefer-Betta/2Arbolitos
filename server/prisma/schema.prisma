generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(WAITER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  attendance Attendance[]

  @@map("users")
}

enum Role {
  ADMIN
  COOK
  WAITER
  CASHIER
  MANAGER
}

model Permission {
  id   String @id @default(uuid())
  name String @unique

  rolePermissions RolePermission[]
}

model RolePermission {
  roleName     String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleName, permissionId])
}


model Category {
  id        String    @id @default(uuid())
  name      String
  active    Boolean   @default(true)
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  price       Float
  isUsd       Boolean     @default(false)
  active      Boolean     @default(true)
  imageUrl    String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems OrderItem[]
  inventoryItems InventoryItem[]
  modifierGroups ProductModifierGroup[]

  @@map("products")
}

model ModifierGroup {
  id       String   @id @default(uuid())
  name     String
  type     ModifierGroupType @default(SINGLE)
  active   Boolean  @default(true)
  createdAt DateTime @default(now())

  modifiers  Modifier[]
  products   ProductModifierGroup[]

  @@map("modifier_groups")
}

enum ModifierGroupType {
  SINGLE
  MULTIPLE
}

model Modifier {
  id        String   @id @default(uuid())
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  price     Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("modifiers")
}

model ProductModifierGroup {
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([productId, groupId])
  @@map("product_modifier_groups")
}

// Inventario de insumos (gaseosas, materias primas, etc.)
model InventoryItem {
  id             String   @id @default(uuid())
  name           String
  sku            String?  @unique   // código de barras (opcional)
  quantity       Float    @default(0)   // unidades o litros
  unit           String   // "lt", "ml", "pcs", etc.
  minStock       Float    @default(0)   // nivel de reposición
  expirationDate DateTime? // fecha de vencimiento (opcional)
  provider       String?   // proveedor del insumo
  unitCost       Float?    // costo unitario del insumo
  productId      String?   // si se asocia a un producto (ej. botella de soda)
  product        Product? @relation(fields: [productId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movements InventoryMovement[]

  @@map("inventory_items")
}

model InventoryMovement {
  id        String   @id @default(uuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])
  quantity  Float    // positivo = entrada, negativo = salida
  previous  Float
  newQuantity Float
  reason    String   // "ajuste", "compra", "venta", "merma", etc.
  userId    String?
  createdAt DateTime @default(now())

  @@map("inventory_movements")
}

model Table {
  id        String     @id @default(uuid())
  number    Int        @unique
  name      String?
  capacity  Int        @default(4)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  orders Order[]
  reservations Reservation[]

  @@map("tables")
}

model TableState {
  id        String   @id @default(uuid())
  tableId   String   @unique
  items     String?  @db.LongText
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("table_states")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("customers")
}

model Order {
  id            String      @id @default(uuid())
  tableId       String?
  table         Table?      @relation(fields: [tableId], references: [id])
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  orderType     OrderType   @default(MESA)
  status        OrderStatus @default(PENDING)
  totalCop      Float       @default(0)
  totalUsd      Float       @default(0)
  exchangeRate  Float       @default(4000)
  exchangeRateBs Float      @default(40)
  discountValue Float       @default(0)
  discountPercent Float     @default(0)
  notes         String?
  deliveryAddress String?
  deliveryPhone  String?
  deliveryCost  Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  items     OrderItem[]
  payments  Payment[]

  @@map("orders")
  @@index([createdAt])
  @@index([userId])
  @@index([customerId])
}

enum OrderType {
  MESA
  PARA_LLEVAR
  DOMICILIO
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  totalPrice Float
  notes     String?
  modifiers Json?
  createdAt DateTime @default(now())

  @@map("order_items")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  currency      String        @default("COP")
  amount        Float
  change        Float         @default(0)
  reference     String?
  createdAt     DateTime      @default(now())

  @@map("payments")
  @@index([orderId])
}

enum PaymentMethod {
  CASH_COP
  CASH_USD
  CASH_BS
  NEQUI
  CARD
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  entity    String   // tabla (ej. Product, InventoryItem)
  entityId  String   // id del registro
  action    String   // CREATE, UPDATE, DELETE
  before    Json?
  after     Json?
  userId    String?  // quien realizó la acción
  timestamp DateTime @default(now())

  @@map("audit_logs")
}

model Closure {
  id            String   @id @default(uuid())
  date         DateTime @default(now())
  orderCount   Int      @default(0)
  totalSalesCOP Float    @default(0)
  totalSalesUSD Float   @default(0)
  totalExpenses Float   @default(0)
  exchangeRate Float    @default(4000)
  notes        String?
  createdAt   DateTime @default(now())

  @@map("closures")
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  category    String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model Reservation {
  id         String            @id @default(uuid())
  customerName String
  phone      String?
  email      String?
  guests     Int               @default(1)
  dateTime   DateTime
  tableId    String?
  table      Table?            @relation(fields: [tableId], references: [id])
  status     ReservationStatus @default(PENDING)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("reservations")
  @@index([dateTime])
  @@index([status])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id         String   @id @default(uuid())
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  items      Json
  total      Float    @default(0)
  status     PurchaseOrderStatus @default(PENDING)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receivedAt DateTime?

  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  checkIn   DateTime @default(now())
  checkOut  DateTime?
  hours     Float    @default(0)
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime @default(now())

  @@map("attendance")
  @@index([userId])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
}
