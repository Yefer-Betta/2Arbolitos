generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(WAITER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("users")
}

enum Role {
  ADMIN
  COOK
  WAITER
  CASHIER
}

model Category {
  id        String    @id @default(uuid())
  name      String
  active    Boolean   @default(true)
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  price       Float
  isUsd       Boolean     @default(false)
  active      Boolean     @default(true)
  imageUrl    String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Table {
  id        String     @id @default(uuid())
  number    Int        @unique
  name      String?
  capacity  Int        @default(4)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  orders Order[]

  @@map("tables")
}

model Order {
  id            String      @id @default(uuid())
  tableId       String?
  table         Table?      @relation(fields: [tableId], references: [id])
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  orderType     OrderType   @default(MESA)
  status        OrderStatus @default(PENDING)
  totalCop      Float       @default(0)
  totalUsd      Float       @default(0)
  exchangeRate  Float       @default(4000)
  discountValue Float       @default(0)
  discountPercent Float     @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  items     OrderItem[]
  payment   Payment?

  @@map("orders")
}

enum OrderType {
  MESA
  PARA_LLEVAR
  DOMICILIO
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  totalPrice Float
  notes     String?
  createdAt DateTime @default(now())

  @@map("order_items")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  currency      String        @default("COP")
  amount        Float
  change        Float         @default(0)
  reference     String?
  createdAt     DateTime      @default(now())

  @@map("payments")
}

enum PaymentMethod {
  CASH_COP
  CASH_USD
  NEQUI
  CARD
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
