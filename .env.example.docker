# === 2Arbolitos - Docker Environment ===
# Copia este archivo a .env y edita los valores

# Contraseña root de MySQL (cámbiala!)
MYSQL_ROOT_PASSWORD=2arbolitos_segura_2024

# Secreto JWT para tokens de autenticación (cámbialo!)
JWT_SECRET=2arbolitos_jwt_$(date +%s)

# IP del servidor en la LAN (déjalo en 0.0.0.0 para autodetección)
HOST_IP=0.0.0.0

# Puerto de acceso a la aplicación (opcional, default 3002)
APP_PORT=3002
